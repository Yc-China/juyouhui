<template>
	<view class="container">
		<!-- 账户信息卡片 -->
		<view class="card balance-card">
			<view class="balance-info">
				<text class="balance-label">账户余额</text>
				<text class="balance-value">¥{{ balance }}</text>
			</view>
			<view class="balance-actions">
				<button class="btn-recharge" @click="goToRecharge">去充值</button>
			</view>
		</view>

		<!-- 数据概览 -->
		<view class="card stats-card">
			<view class="stats-item">
				<text class="stats-value">{{ todayPoints }}</text>
				<text class="stats-label">今日发放积分</text>
			</view>
			<view class="stats-divider"></view>
			<view class="stats-item">
				<text class="stats-value">{{ totalPoints }}</text>
				<text class="stats-label">累计发放积分</text>
			</view>
		</view>

		<!-- 功能菜单 -->
		<view class="grid-menu">
			<view class="menu-item" @click="goToScan">
				<view class="menu-icon scan-icon">
					<text class="icon">🔍</text>
				</view>
				<text class="menu-text">扫码发积分</text>
			</view>
			<view class="menu-item" @click="goToRecord">
				<view class="menu-icon record-icon">
					<text class="icon">📋</text>
				</view>
				<text class="menu-text">积分记录</text>
			</view>
			<view class="menu-item" @click="goToStore">
				<view class="menu-icon store-icon">
					<text class="icon">🏪</text>
				</view>
				<text class="menu-text">门店管理</text>
			</view>
			<view class="menu-item" @click="goToBalance">
				<view class="menu-icon balance-icon">
					<text class="icon">💰</text>
				</view>
				<text class="menu-text">余额明细</text>
			</view>
		</view>
	</view>
</template>

<script lang="uts" setup>
	import { ref } from 'vue'
	import { getHomeStatsApi } from '@/api/home'

	const balance = ref(0.00) // 账户余额（元）
	const todayPoints = ref(0) // 今日发放积分
	const totalPoints = ref(0) // 累计发放积分

	async function loadData() {
		try {
			const res = await getHomeStatsApi()
			balance.value = res.balance
			todayPoints.value = res.todayPoints
			totalPoints.value = res.totalPoints
		} catch (e) {
			console.error('加载首页数据失败', e)
		}
	}

	function goToRecharge() {
		uni.navigateTo({
			url: '/pages/balance/balance'
		})
	}

	function goToScan() {
		uni.switchTab({
			url: '/pages/scan/scan'
		})
	}

	function goToRecord() {
		uni.navigateTo({
			url: '/pages/point-record/point-record'
		})
	}

	function goToStore() {
		uni.navigateTo({
			url: '/pages/store/store'
		})
	}

	function goToBalance() {
		uni.navigateTo({
			url: '/pages/balance/balance'
		})
	}

	// uni-app x 生命周期挂载方式
	onShow(function () {
		loadData()
	})
</script>

