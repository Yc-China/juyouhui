<template>
	<view class="container">
		<view class="logo">
			<text class="logo-text">聚优惠</text>
			<text class="logo-subtitle">商家后台</text>
		</view>

		<view class="form">
			<view class="form-item">
				<input class="input" v-model="username" placeholder="请输入账号" placeholder-class="placeholder" />
			</view>
			<view class="form-item">
				<input class="input" v-model="password" type="password" placeholder="请输入密码" placeholder-class="placeholder" />
			</view>

			<button class="btn-login" @click="handleLogin" :loading="loading">{{ loading ? '登录中...' : '登录' }}</button>
		</view>

		<view class="footer">
			<text>© 2026 聚优惠</text>
		</view>
	</view>
</template>

<script lang="uts" setup>
	import { ref } from 'vue'
	import { loginApi } from '@/api/auth'
	import { TOKEN_KEY, MERCHANT_INFO_KEY } from '@/api/config'

	const username = ref('')
	const password = ref('')
	const loading = ref(false)

	async function handleLogin() {
		console.log('输入值', username.value, password.value)

		if (!username.value.trim() || !password.value.trim()) {
			uni.showToast({
				title: '请输入账号和密码',
				icon: 'none'
			})
			return
		}

		loading.value = true

		try {
			const res = await loginApi({
				contactPhone: username.value.trim(),
				password: password.value.trim()
			})

			// 保存登录信息
			uni.setStorageSync(TOKEN_KEY, res.token)
			uni.setStorageSync(MERCHANT_INFO_KEY, res.merchant)

			uni.showToast({
				title: '登录成功',
				icon: 'success'
			})

			setTimeout(() => {
				uni.switchTab({
					url: '/pages/index/index'
				})
			}, 1000)
		} catch (e) {
			console.error(e)
		} finally {
			loading.value = false
		}
	}
</script>

