	.container {
		min-height: 100vh;
		padding: 150rpx 40rpx 40rpx;
		box-sizing: border-box;
		background: linear-gradient(180deg, #3cc51f 0%, #5cd942 100%);
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.logo {
		margin-bottom: 100rpx;
		text-align: center;
	}

	.logo-text {
		display: block;
		font-size: 80rpx;
		font-weight: bold;
		color: #ffffff;
		margin-bottom: 20rpx;
	}

	.logo-subtitle {
		display: block;
		font-size: 28rpx;
		color: rgba(255, 255, 255, 0.8);
	}

	.form {
		width: 100%;
		background-color: #fff;
		border-radius: 20rpx;
		padding: 50rpx 30rpx 30rpx;
		box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
	}

	.form-item {
		margin-bottom: 30rpx;
		background-color: #fafafa;
		border-radius: 10rpx;
		padding: 0 30rpx;
	}

	.input {
		width: 100%;
		height: 100rpx;
		font-size: 32rpx;
	}

	.placeholder {
		color: #ccc;
	}

	.btn-login {
		width: 100%;
		height: 90rpx;
		background-color: #3cc51f;
		color: #fff;
		font-size: 34rpx;
		border-radius: 10rpx;
		margin-top: 40rpx;
		line-height: 90rpx;
		padding: 0;
	}

	.footer {
		margin-top: auto;
		padding-top: 100rpx;
		color: rgba(255, 255, 255, 0.7);
		font-size: 24rpx;
	}
</style>
