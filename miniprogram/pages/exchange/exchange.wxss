/* exchange.wxss */
.create-container {
  min-height: 100vh;
}

.product-info {
  display: flex;
  margin-top: 20rpx;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.product-detail {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.product-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.product-points {
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.product-desc {
  line-height: 1.5;
}

.address-card {
  margin-top: 20rpx;
}

.empty-address {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: #666;
  font-size: 30rpx;
}

.selected-address {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.receiver {
  margin-bottom: 10rpx;
}

.receiver text {
  font-size: 30rpx;
  color: #333;
}

.receiver .phone {
  margin-left: 20rpx;
  color: #666;
}

.address-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.arrow {
  color: #ccc;
  align-self: center;
}

.points-summary {
  margin-top: 20rpx;
}

.summary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
}

.summary-item.total {
  border-top: 1rpx solid #eee;
  margin-top: 10rpx;
  padding-top: 20rpx;
  font-weight: bold;
}

.submit-btn {
  position: fixed;
  bottom: 40rpx;
  left: 40rpx;
  right: 40rpx;
}

.error-tip {
  text-align: center;
  color: #ff4d4f;
  margin-top: 16rpx;
}

/* 订单列表样式 */
.order-item {
  margin: 20rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.order-number {
  font-size: 26rpx;
  color: #666;
}

.order-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 4rpx;
}

.status-wait {
  background-color: #FFF7E6;
  color: #FA8C16;
}

.status-send {
  background-color: #E6F7FF;
  color: #1890FF;
}

.status-done {
  background-color: #F6FFED;
  color: #52C41A;
}

.order-body {
  display: flex;
}

.order-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  background-color: #f5f5f5;
}

.order-info {
  flex: 1;
  margin-left: 20rpx;
}

.order-name {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.order-points {
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.order-time {
  color: #999;
}

.loading, .empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}
