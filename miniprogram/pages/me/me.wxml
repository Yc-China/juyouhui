<!--me.wxml-->
<view class="container">
  <view class="user-card">
    <view class="user-info">
      <image class="avatar" src="{{userInfo.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="user-detail">
        <view class="nickname">{{userInfo.nickname || '微信用户'}}</view>
        <view class="phone">{{userInfo.phone || ''}}</view>
      </view>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToPoints">
      <text class="menu-text">积分流水</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToExchange">
      <text class="menu-text">我的订单</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="logout">
      <text class="menu-text exit-text">退出登录</text>
      <text class="arrow">></text>
    </view>
  </view>
</view>
