/* index.wxss */
.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
}

.login-logo {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 100rpx;
}

.logo-text {
  font-size: 80rpx;
  font-weight: bold;
  color: #FF6B35;
  margin-bottom: 20rpx;
}

.logo-desc {
  font-size: 28rpx;
  color: #999;
}

.login-tip {
  color: #666;
  font-size: 26rpx;
  text-align: center;
  line-height: 1.6;
}

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.points-card {
  background: linear-gradient(135deg, #FF6B35 0%, #FF8A5C 100%);
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 40rpx;
  color: white;
}

.points-info {
  display: flex;
  justify-content: space-between;
}

.available-points {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.points-value {
  font-size: 64rpx;
  font-weight: bold;
}

.total-points {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: flex-end;
}

.total-label {
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 10rpx;
}

.total-value {
  font-size: 36rpx;
}

.grid-menu {
  display: flex;
  flex-wrap: wrap;
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 20rpx 0;
}

.menu-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.menu-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background-color: #FFF1EB;
}

.gift-icon {
  background: #FFF1EB url('/images/gift.png') center center no-repeat;
  background-size: 50%;
}

.points-icon {
  background: #FFF1EB url('/images/points.png') center center no-repeat;
  background-size: 50%;
}

.order-icon {
  background: #FFF1EB url('/images/order.png') center center no-repeat;
  background-size: 50%;
}

.me-icon {
  background: #FFF1EB url('/images/me.png') center center no-repeat;
  background-size: 50%;
}

.menu-item text {
  font-size: 26rpx;
  color: #333;
}

.notice-card {
  margin: 20rpx;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
}

.notice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.notice-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
