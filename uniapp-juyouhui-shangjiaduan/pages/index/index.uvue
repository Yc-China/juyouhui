		color: #333;
		margin-bottom: 10rpx;
	}

	.stats-label {
		display: block;
		font-size: 26rpx;
		color: #999;
	}

	.stats-divider {
		width: 1px;
		background-color: #eee;
	}

	.grid-menu {
		display: flex;
		flex-wrap: wrap;
		background-color: #fff;
		border-radius: 16rpx;
		padding: 20rpx 0;
	}

	.menu-item {
		width: 25%;
		text-align: center;
		padding: 20rpx 0;
	}

	.menu-icon {
		width: 80rpx;
		height: 80rpx;
		border-radius: 16rpx;
		display: flex;
